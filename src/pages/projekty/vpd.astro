---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import InlineCTA from '../../components/InlineCTA.astro';
import InvestmentHero from '../../components/InvestmentHero.astro';
import { withBase } from '../../utils/url';

// VPD struktura — tři pilíře činnosti, každý s několika autonomními
// záměry. Tam kde záměr má vlastní stránku v rámci osa-web, vede
// klikatelný odkaz; ostatní zůstávají placeholder bez href, protože
// tyto stránky teprve vznikají.
const vpdStructure = [
  {
    n: '01',
    label: 'Software',
    note: 'Rozvoj lidských zdrojů a jimi generovaných programů',
    items: [
      { name: 'Startup Factory',                href: null },
      { name: 'Stipendijní Fond VPD',           href: null },
      { name: 'Vzdělávací a inkubační programy', href: withBase('/projekty/projektovy-inkubator/') },
    ],
  },
  {
    n: '02',
    label: 'Hardware',
    note: 'Rozvoj staveb, technologií a všeho, na čem software funguje',
    items: [
      { name: 'Záměr VPD1 — Horní kasárna Klecany', href: null, primary: true },
      { name: 'Startovací Hub Dynamitka',           href: null },
      { name: 'Komunitní centrum Klecany',          href: null },
      { name: 'Coworking centrum Klecany',          href: null },
    ],
  },
  {
    n: '03',
    label: 'Finance',
    note: 'Kapitálové a institucionální struktury, které celý ekosystém umožňují',
    items: [
      { name: 'Družstevní záložna VPD',           href: null },
      { name: 'Fond kvalifikovaných investorů',   href: null },
      { name: 'Nadace VPD',                       href: null },
      { name: 'Bytové družstvo VPD',              href: null },
    ],
  },
];
---
<Base
  title="Veřejně prospěšný developer (VPD) - autonomní projekt OSA"
  description="Spin-off OSA II. Veřejně prospěšný rozvoj softwaru a hardwaru — lidských zdrojů, programů, staveb a technologií.">
  <Header variant="dark" />

  <main class="osa-vpd">

    <section class="osa-vpd__hero osa-dark">
      <div class="osa-vpd__hero-inner">
        <nav aria-label="Drobečková navigace" class="osa-vpd__crumbs osa-eyebrow">
          <a href={withBase('/')}>Úvod</a> <span aria-hidden="true">·</span>
          <a href={withBase('/projekty/')}>Projekty</a> <span aria-hidden="true">·</span>
          <span aria-current="page">Veřejně prospěšný developer</span>
        </nav>
        <div class="osa-vpd__hero-grid">
          <h1 class="osa-vpd__brand" data-reveal>
            <span class="sr-only">Veřejně prospěšný developer</span>
            <span class="osa-vpd__brand-bar" aria-hidden="true"></span>
            <span class="osa-vpd__brand-word" aria-hidden="true">Veřejně</span>
            <span class="osa-vpd__brand-word" aria-hidden="true">Prospěšný</span>
            <span class="osa-vpd__brand-word" aria-hidden="true">Developer</span>
          </h1>
          <div class="osa-vpd__hero-copy">
            <p class="osa-vpd__h1-sub" data-reveal>Spin-off OSA II. Veřejně prospěšný rozvoj softwaru a hardwaru.</p>
            <p class="osa-vpd__lede" data-reveal data-reveal-delay="1">
              VPD je spin-off občanského sdružení Alternativa II, jehož posláním je pomáhat realizovat poslání spolku <a href={withBase('/o-spolku/')}>osa2.cz</a> veřejně prospěšným způsobem — v mezích aktuálních hodnot organizace a komerčně uchopitelným způsobem.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="osa-vpd__stats section--tight">
      <div class="osa-vpd__wrap">
        <dl class="osa-vpd__stat-grid" data-reveal>
          <div>
            <dt class="osa-eyebrow">Vznik</dt>
            <dd class="osa-vpd__stat-v">2020</dd>
          </div>
          <div>
            <dt class="osa-eyebrow">Vztah ke spolku</dt>
            <dd class="osa-vpd__stat-v">Spin-off OSA II</dd>
          </div>
          <div>
            <dt class="osa-eyebrow">Princip</dt>
            <dd class="osa-vpd__stat-v">Komerčně uchopitelná veřejná prospěšnost</dd>
          </div>
          <div>
            <dt class="osa-eyebrow">Kontakt</dt>
            <dd class="osa-vpd__stat-v">
              <a href="https://vepde.com" target="_blank" rel="noopener">vepde.com</a>
            </dd>
          </div>
        </dl>
      </div>
    </section>

    {/* ===== SOFTWARE & HARDWARE FRAMING ===== */}
    <section class="section">
      <div class="osa-vpd__wrap">
        <header class="osa-sub-head" data-reveal>
          <span class="osa-eyebrow">Co VPD dělá</span>
          <h2>Veřejně prospěšný rozvoj softwaru a hardwaru.</h2>
        </header>
        <div class="osa-vpd__framing" data-reveal>
          <article>
            <span class="osa-mono osa-vpd__framing-num">SW</span>
            <h3 class="osa-h3">Software</h3>
            <p class="osa-body">
              Primárně rozvoj <strong>lidských zdrojů</strong> a jimi generovaných <strong>programů</strong>. Lidské know-how, vzdělávání, mentoring, akcelerační programy, projektový management, právní a organizační záštita.
            </p>
          </article>
          <article>
            <span class="osa-mono osa-vpd__framing-num">HW</span>
            <h3 class="osa-h3">Hardware</h3>
            <p class="osa-body">
              Rozvoj všeho, co má materiální povahu — toho, <strong>kde a na čem software funguje</strong>, či s čím tento software pracuje. Stavby, počítače, stroje a těla.
            </p>
          </article>
        </div>
      </div>
    </section>

    {/* ===== STRUKTURA — rozcestník přes záměry VPD ===== */}
    <section class="section osa-vpd__structure">
      <div class="osa-vpd__wrap">
        <header class="osa-sub-head" data-reveal>
          <span class="osa-eyebrow">Struktura</span>
          <h2>Tři pilíře, mnoho záměrů.</h2>
          <p class="osa-vpd__structure-lede osa-body">
            VPD funguje jako platforma pro síť autonomních záměrů. Některé jsou softwarové (programy, lidské zdroje), jiné hardwarové (stavby, technologie), další podpůrné (kapitálové a institucionální struktury). Pod centrálním VPD najdete:
          </p>
        </header>

        <div class="osa-vpd__graph" role="presentation" data-reveal>
          <div class="osa-vpd__graph-node osa-vpd__graph-root">
            <span class="osa-eyebrow">Centrální záměr</span>
            <strong>VPD</strong>
            <span class="osa-vpd__graph-note">Spin-off OSA II</span>
          </div>
          <div class="osa-vpd__graph-branches">
            {vpdStructure.map((tier) => (
              <div class="osa-vpd__graph-branch">
                <header class="osa-vpd__graph-tier">
                  <span class="osa-mono osa-vpd__graph-num">{tier.n}</span>
                  <div>
                    <strong class="osa-vpd__graph-tier-label">{tier.label}</strong>
                    <span class="osa-vpd__graph-tier-note">{tier.note}</span>
                  </div>
                </header>
                <ul class="osa-vpd__graph-leaves" role="list">
                  {tier.items.map((it) => (
                    <li class={`osa-vpd__graph-leaf${it.primary ? ' osa-vpd__graph-leaf--primary' : ''}`}>
                      {it.href ? (
                        <a href={it.href} class="osa-nolink">
                          <span class="osa-vpd__graph-dot" aria-hidden="true"></span>
                          <span>{it.name}</span>
                          <span class="osa-vpd__graph-arrow" aria-hidden="true">→</span>
                        </a>
                      ) : (
                        <span>
                          <span class="osa-vpd__graph-dot" aria-hidden="true"></span>
                          <span>{it.name}</span>
                        </span>
                      )}
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    {/* ===== AREÁL KLECANY — site plan + render ===== */}
    <section class="section osa-vpd__areal">
      <div class="osa-vpd__wrap">
        <header class="osa-sub-head" data-reveal>
          <span class="osa-eyebrow">Záměr VPD1</span>
          <h2>Horní kasárna Klecany.</h2>
          <p class="osa-vpd__areal-lede osa-body">
            Hlavní hardwarový záměr VPD: revitalizace bývalého vojenského areálu na multifunkční komunitní centrum. Schéma areálu níže ukazuje kompozici budoucích provozů a navazujících veřejných prostor.
          </p>
        </header>
        <div class="osa-vpd__areal-grid" data-reveal>
          <figure class="osa-vpd__areal-fig osa-vpd__areal-fig--map">
            <img src={withBase('/images/areal/areal-mapa.jpg')} alt="Schematický pohled (2D mapa) na areál Horních kasáren Klecany s vyznačenými budovami a navazujícími veřejnými prostory." loading="lazy" />
            <figcaption>Schéma areálu — 2D mapa</figcaption>
          </figure>
          <figure class="osa-vpd__areal-fig">
            <img src={withBase('/images/areal/sh-1.jpg')} alt="Vizualizace Startovacího Hubu v Horních kasárnách Klecany — pohled na centrální plochu mezi budovami." loading="lazy" />
            <figcaption>Vizualizace — Startovací Hub Klecany</figcaption>
          </figure>
        </div>
        <div class="osa-vpd__areal-strip" data-reveal data-reveal-delay="1">
          <figure>
            <img src={withBase('/images/areal/sh-2.jpg')} alt="Detailní vizualizace startovacího hubu Klecany — interiér společných prostor." loading="lazy" />
          </figure>
          <figure>
            <img src={withBase('/images/areal/sh-3.jpg')} alt="Vizualizace klecanského areálu — pohled z ulice na vstupní část objektu." loading="lazy" />
          </figure>
          <figure>
            <img src={withBase('/images/areal/sh-4.jpg')} alt="Vizualizace areálu Klecany — letní pobytová terasa a komunitní zóna." loading="lazy" />
          </figure>
        </div>
      </div>
    </section>

    {/* InvestmentHero banner — stejná komponenta jako na úvodu. */}
    <InvestmentHero hideVpdLink={true} />

    <section class="section--tight osa-vpd__linked">
      <div class="osa-vpd__wrap">
        <div class="osa-vpd__linked-grid" data-reveal>
          <div>
            <span class="osa-eyebrow">Související projekty</span>
            <h3 class="osa-h3">Městský inkubátor CZ</h3>
            <p class="osa-body">
              Taktický urbanismus a meanwhile-use brownfieldů. Modulární kontejnerová infrastruktura, pop-up kluby, dílny, gastronomické zóny. Testuje reálné potřeby obyvatel předtím, než přijde trvalá zástavba.
            </p>
            <InlineCTA href={withBase('/projekty/mestsky-inkubator/')}>O projektu</InlineCTA>
          </div>
          <div>
            <span class="osa-eyebrow">Související projekty</span>
            <h3 class="osa-h3">Výletná</h3>
            <p class="osa-body">
              Historická dřevěná klubovna v Letenských sadech. Vlajková případová studie VPD. Aktuálně kampaň <span class="osa-vpd__hashtag">#podporujVYLETNOU</span> za obnovu provozu.
            </p>
            <InlineCTA href="https://podporujvyletnou.cz" external={true}>podporujvyletnou.cz</InlineCTA>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Base>

<style>
  .osa-vpd__wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--gutter);
    width: 100%;
  }

  .osa-vpd__hero { border-bottom: 1px solid var(--rule); }
  .osa-vpd__hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: clamp(var(--space-7), 8vw, var(--space-9)) var(--gutter) var(--space-9);
    display: grid;
    gap: var(--space-5);
  }
  .osa-vpd__crumbs {
    display: flex; gap: var(--space-2); flex-wrap: wrap;
    color: var(--fg-muted);
  }
  .osa-vpd__crumbs a { text-decoration: underline; text-underline-offset: 3px; }
  .osa-vpd__crumbs [aria-current] { color: var(--fg); }

  .osa-vpd__hero-grid {
    display: grid;
    grid-template-columns: minmax(260px, 1fr) 1.3fr;
    gap: var(--space-7);
    align-items: start;
  }
  @media (max-width: 860px) {
    .osa-vpd__hero-grid { grid-template-columns: 1fr; gap: var(--space-6); }
  }

  .osa-vpd__brand {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(1.75rem, 3.4vw + 0.5rem, 2.875rem);
    line-height: 1;
    letter-spacing: var(--tracking-tight);
    color: var(--fg);
    margin: 0;
    padding-top: clamp(0.25rem, 0.35vw, 0.4rem);
    display: grid;
    gap: 0;
    width: max-content;
    max-width: 100%;
  }
  .osa-vpd__brand-bar {
    display: block;
    height: 0.45em;
    width: 100%;
    background: currentColor;
    clip-path: polygon(0.26em 0, 100% 0, 100% 100%, 0 100%);
    margin-bottom: 0.18em;
  }
  .osa-vpd__brand-word { display: block; line-height: 1; }

  .osa-vpd__hero-copy {
    display: grid;
    gap: var(--space-4);
    max-width: 56ch;
  }
  .osa-vpd__h1-sub {
    color: var(--fg);
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(1.5rem, 2.2vw + 0.5rem, 2.25rem);
    line-height: 1.1;
    letter-spacing: var(--tracking-tight);
    margin: 0;
    text-wrap: balance;
  }
  .osa-vpd__lede {
    color: var(--fg-muted);
    font-size: var(--text-lg);
    margin: 0;
  }
  .osa-vpd__lede a {
    color: var(--fg);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .osa-vpd__stat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0;
    margin: 0;
    border: 1px solid var(--rule);
  }
  .osa-vpd__stat-grid > div {
    padding: var(--space-4) var(--space-5);
    border-right: 1px solid var(--rule);
    display: grid;
    gap: var(--space-2);
  }
  .osa-vpd__stat-grid > div:last-child { border-right: 0; }
  .osa-vpd__stat-grid dt { color: var(--fg-muted); }
  .osa-vpd__stat-grid dd {
    margin: 0;
    font: 600 var(--text-md) / var(--lh-snug) var(--font-sans);
    letter-spacing: var(--tracking-tight);
  }
  @media (max-width: 720px) {
    .osa-vpd__stat-grid > div { border-right: 0; border-bottom: 1px solid var(--rule); }
    .osa-vpd__stat-grid > div:last-child { border-bottom: 0; }
  }

  /* ---------- Software / Hardware framing ---------- */
  .osa-vpd__framing {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border: 1px solid var(--rule);
  }
  .osa-vpd__framing > article {
    padding: var(--space-5);
    border-right: 1px solid var(--rule);
    display: grid;
    gap: var(--space-3);
    align-content: start;
  }
  .osa-vpd__framing > article:last-child { border-right: 0; }
  .osa-vpd__framing-num {
    color: var(--fg-muted);
    font-size: var(--text-md);
    letter-spacing: var(--tracking-wide);
  }
  .osa-vpd__framing h3 { margin: 0; }
  .osa-vpd__framing p { margin: 0; color: var(--fg); }
  @media (max-width: 720px) {
    .osa-vpd__framing { grid-template-columns: 1fr; }
    .osa-vpd__framing > article { border-right: 0; border-bottom: 1px solid var(--rule); }
    .osa-vpd__framing > article:last-child { border-bottom: 0; }
  }

  /* ---------- Structural diagram (Obsidian-graph–inspired) ---------- */
  .osa-vpd__structure-lede { margin: var(--space-2) 0 0; color: var(--fg-muted); max-width: 60ch; }

  .osa-vpd__graph {
    display: grid;
    gap: var(--space-6);
    margin-top: var(--space-2);
  }
  .osa-vpd__graph-root {
    justify-self: center;
    text-align: center;
    border: 1px solid var(--fg);
    padding: var(--space-4) var(--space-6);
    display: grid;
    gap: var(--space-1);
    min-width: 200px;
  }
  .osa-vpd__graph-root .osa-eyebrow { color: var(--fg-muted); }
  .osa-vpd__graph-root strong {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--text-2xl);
    letter-spacing: var(--tracking-tight);
    line-height: 1;
  }
  .osa-vpd__graph-note {
    font-size: var(--text-2xs);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--fg-muted);
  }

  /* Tenká spojnice mezi rootem a větvemi */
  .osa-vpd__graph::before {
    content: "";
    width: 1px;
    height: var(--space-5);
    background: var(--fg-muted);
    justify-self: center;
    grid-row: 2;
    margin-bottom: calc(-1 * var(--space-5));
    opacity: 0.5;
  }

  .osa-vpd__graph-branches {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: 1px solid var(--rule);
    border-left: 1px solid var(--rule);
  }
  .osa-vpd__graph-branch {
    display: grid;
    gap: var(--space-3);
    padding: var(--space-5);
    border-right: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    align-content: start;
  }
  @media (max-width: 900px) {
    .osa-vpd__graph-branches { grid-template-columns: 1fr; }
  }

  .osa-vpd__graph-tier {
    display: grid;
    grid-template-columns: 36px 1fr;
    gap: var(--space-3);
    align-items: start;
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--rule);
  }
  .osa-vpd__graph-num {
    color: var(--fg-muted);
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-wide);
  }
  .osa-vpd__graph-tier-label {
    display: block;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--text-lg);
    letter-spacing: var(--tracking-tight);
    line-height: 1.2;
  }
  .osa-vpd__graph-tier-note {
    display: block;
    margin-top: 4px;
    font-size: var(--text-2xs);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--fg-muted);
    max-width: 32ch;
  }

  .osa-vpd__graph-leaves {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-1);
  }
  .osa-vpd__graph-leaf {
    font-size: var(--text-sm);
    line-height: var(--lh-tight);
    color: var(--fg);
  }
  .osa-vpd__graph-leaf > a,
  .osa-vpd__graph-leaf > span {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) 0;
    text-decoration: none;
    color: inherit;
  }
  .osa-vpd__graph-leaf > a {
    border-bottom: 1px solid transparent;
    transition: border-color var(--dur-base, 280ms) var(--ease-quart);
  }
  .osa-vpd__graph-leaf > a:hover,
  .osa-vpd__graph-leaf > a:focus-visible {
    border-bottom-color: var(--fg);
    opacity: 1;
  }
  .osa-vpd__graph-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--fg);
    opacity: 0.6;
  }
  .osa-vpd__graph-leaf--primary .osa-vpd__graph-dot {
    opacity: 1;
    width: 8px;
    height: 8px;
  }
  .osa-vpd__graph-leaf--primary > * { font-weight: 600; }
  .osa-vpd__graph-arrow {
    color: var(--fg-muted);
    font-size: var(--text-sm);
    line-height: 1;
  }

  /* ---------- Areál Klecany — site plan + renders ---------- */
  .osa-vpd__areal-lede { margin: var(--space-2) 0 0; color: var(--fg-muted); max-width: 64ch; }

  .osa-vpd__areal-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin-top: var(--space-2);
  }
  .osa-vpd__areal-fig {
    margin: 0;
    border: 1px solid var(--rule);
    background: var(--bg);
    overflow: hidden;
  }
  .osa-vpd__areal-fig img {
    display: block;
    width: 100%;
    height: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }
  .osa-vpd__areal-fig--map img {
    object-fit: contain;
    background: var(--k-5);
    padding: var(--space-3);
  }
  .osa-vpd__areal-fig figcaption {
    padding: var(--space-3) var(--space-4);
    color: var(--fg-muted);
    font-size: var(--text-2xs);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    border-top: 1px solid var(--rule);
  }

  .osa-vpd__areal-strip {
    margin-top: var(--space-4);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }
  .osa-vpd__areal-strip figure { margin: 0; border: 1px solid var(--rule); overflow: hidden; }
  .osa-vpd__areal-strip img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  @media (max-width: 720px) {
    .osa-vpd__areal-grid { grid-template-columns: 1fr; }
    .osa-vpd__areal-strip { grid-template-columns: 1fr 1fr; }
  }

