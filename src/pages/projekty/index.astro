---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const all = await getCollection('subProjects', e => e.data.status !== 'draft');
const sorted = all.sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));

const realizovane = sorted.filter(p => p.data.status === 'realizovany' || p.data.status === 've-spanku');
const pripravovane = sorted.filter(p => p.data.status === 'pripravovany');
---
<Base title="Projekty - Občanské sdružení Alternativa II">
  <Header variant="dark" />
  <main class="osa-projekty">
    <section class="osa-projekty__hero osa-dark">
      <div class="container-wide osa-projekty__hero-inner">
        <header class="osa-projekty__head" data-reveal>
          <span class="osa-eyebrow">Autonomní projekty</span>
          <h1 class="osa-projekty__h1">
            Pod hlavičkou OSA působí desítky autonomních projektů.
            <span class="osa-projekty__h1-sub">
              Každý si vede vlastní prostor, web, členskou základnu a hospodaření. Spolek poskytuje právní a organizační zázemí.
            </span>
          </h1>
        </header>
      </div>
    </section>

    <section class="section">
      <div class="container-wide">
        <div class="osa-projekty__group" data-reveal>
          <header class="osa-projekty__group-head">
            <span class="osa-eyebrow">Realizované</span>
          </header>
          <ul class="osa-projekty__grid" role="list">
            {realizovane.map((p, i) => (
              <li data-reveal data-reveal-delay={String((i % 4) + 1)}><ProjectCard
                slug={p.id}
                name={p.data.name}
                description={p.data.description}
                accent={p.data.accent}
                relationship={p.data.relationship}
                status={p.data.status}
                topic={p.data.topic}
                external_url={p.data.external_url}
                image={p.data.image}
              /></li>
            ))}
          </ul>
        </div>

        <div class="osa-projekty__group" data-reveal>
          <header class="osa-projekty__group-head">
            <span class="osa-eyebrow">Připravované</span>
          </header>
          <ul class="osa-projekty__grid" role="list">
            {pripravovane.map((p, i) => (
              <li data-reveal data-reveal-delay={String((i % 4) + 1)}><ProjectCard
                slug={p.id}
                name={p.data.name}
                description={p.data.description}
                accent={p.data.accent}
                relationship={p.data.relationship}
                status={p.data.status}
                topic={p.data.topic}
                external_url={p.data.external_url}
                image={p.data.image}
              /></li>
            ))}
          </ul>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Base>

<style>
  /* ---------- Dark hero frame ---------- */

  .osa-projekty__hero {
    border-bottom: 1px solid var(--rule);
    position: relative;
    isolation: isolate;
  }
  .osa-projekty__hero-inner { position: relative; z-index: 1; }
  .osa-projekty__hero-inner {
    padding-top: clamp(var(--space-7), 8vw, var(--space-9));
    padding-bottom: var(--space-9);
    display: grid;
    gap: var(--space-6);
  }

  .osa-projekty__head {
    display: grid;
    gap: var(--space-3);
    max-width: 72ch;
  }
  .osa-projekty__h1 {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(2.25rem, 5vw + 0.5rem, 4rem);
    line-height: 1.05;
    letter-spacing: var(--tracking-tight);
    color: var(--fg);
    margin: 0;
    max-width: 22ch;
    text-wrap: balance;
  }
  .osa-projekty__h1-sub {
    display: block;
    color: var(--fg-muted);
    font-weight: 500;
    font-size: clamp(1.25rem, 1.8vw + 0.5rem, 1.75rem);
    margin-top: var(--space-3);
    max-width: 34ch;
  }

  /* ---------- Groups ---------- */

  .osa-projekty__group + .osa-projekty__group {
    margin-top: var(--space-9);
  }
  .osa-projekty__group-head {
    margin: 0 0 var(--space-4);
  }

  /* ---------- Grid ---------- */

  .osa-projekty__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 1fr;
    gap: 0;
    border-top: 1px solid var(--rule);
    border-left: 1px solid var(--rule);
  }
  .osa-projekty__grid > li { display: flex; }
  .osa-projekty__grid > li > * { flex: 1; }

  @media (max-width: 1024px) {
    .osa-projekty__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .osa-projekty__grid { grid-template-columns: 1fr; }
  }
</style>
