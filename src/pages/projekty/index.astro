---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FilterBar from '../../components/FilterBar.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const all = await getCollection('subProjects', e => e.data.status !== 'draft');
const sorted = all.sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));
---
<Base title="Projekty - Občanské sdružení Alternativa II">
  <Header />
  <main class="osa-projekty">
    <section class="section">
      <div class="container-wide">
        <header class="osa-projekty__head">
          <span class="osa-eyebrow">Autonomní projekty</span>
          <h1 class="osa-h1 osa-projekty__title">Pod hlavičkou OSA působí desítky autonomních projektů.</h1>
          <p class="osa-body osa-projekty__lede">
            Každý si vede vlastní prostor, web, členskou základnu a hospodaření. Spolek poskytuje právní a organizační zázemí.
          </p>
        </header>

        <FilterBar />

        <ul class="osa-projekty__grid" role="list" data-filter-target>
          {sorted.map(p => (
            <li data-filter-item><ProjectCard
              slug={p.id}
              name={p.data.name}
              description={p.data.description}
              accent={p.data.accent}
              relationship={p.data.relationship}
              status={p.data.status}
              topic={p.data.topic}
              external_url={p.data.external_url}
              filterable={true}
            /></li>
          ))}
        </ul>
      </div>
    </section>
  </main>
  <Footer />
</Base>

<style>
  .osa-projekty__head {
    display: grid;
    gap: var(--space-3);
    max-width: 72ch;
    margin: 0 0 var(--space-7);
  }
  .osa-projekty__title { margin: 0; }
  .osa-projekty__lede  { margin: 0; color: var(--fg-muted); }
  .osa-projekty__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    grid-auto-rows: 1fr;
    gap: 0;
    border-top: 1px solid var(--rule);
    border-left: 1px solid var(--rule);
  }
  .osa-projekty__grid > li {
    display: flex;
    transition:
      opacity var(--dur-base) var(--ease-standard),
      transform var(--dur-base) var(--ease-standard),
      filter var(--dur-base) var(--ease-standard);
  }
  .osa-projekty__grid > li > * { flex: 1; }
  .osa-projekty__grid > li[data-filter-out] {
    opacity: 0;
    transform: scale(0.97) translateY(6px);
    pointer-events: none;
  }
  .osa-projekty__grid > li[hidden] { display: none; }
  @media (prefers-reduced-motion: reduce) {
    .osa-projekty__grid > li { transition: none; }
    .osa-projekty__grid > li[data-filter-out] { transform: none; }
  }
</style>
