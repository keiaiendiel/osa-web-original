---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import InlineCTA from '../../components/InlineCTA.astro';

const all = await getCollection('subProjects', e => e.data.status !== 'draft');
const sorted = all.sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));

const realizovane = sorted.filter(p => p.data.status === 'realizovany' || p.data.status === 've-spanku');
const pripravovane = sorted.filter(p => p.data.status === 'pripravovany');
---
<Base title="Projekty - Občanské sdružení Alternativa II">
  <Header variant="dark" />
  <main class="osa-projekty">
    <section class="osa-projekty__hero osa-dark">
      <div class="container-wide osa-projekty__hero-inner">
        <header class="osa-projekty__head" data-reveal>
          <span class="osa-eyebrow">Naše spolkové projekty</span>
          <h1 class="osa-projekty__h1">
            Naše projekty
            <span class="osa-projekty__h1-sub">
              Hlavním výkonným orgánem spolku, který realizuje poslání spolku, jsou autonomní projekty, přičemž v této sekci webu jsou uvedeny zejména ty projekty, které svou činností, záměry či plány nejvíce zaujaly spolkové představenstvo.
            </span>
          </h1>
          <nav class="osa-projekty__jumps" aria-label="Sekce projektů">
            <a class="osa-projekty__jump" href="#realizovane">
              <span class="osa-projekty__jump-eyebrow osa-eyebrow">{realizovane.length} projektů</span>
              <span class="osa-projekty__jump-label">Realizované ↓</span>
            </a>
            <a class="osa-projekty__jump" href="#pripravovane">
              <span class="osa-projekty__jump-eyebrow osa-eyebrow">{pripravovane.length} projektů</span>
              <span class="osa-projekty__jump-label">Připravované ↓</span>
            </a>
          </nav>
        </header>
      </div>
    </section>

    <section class="section">
      <div class="container-wide">
        <div id="realizovane" class="osa-projekty__group" data-reveal>
          <header class="osa-projekty__group-head">
            <span class="osa-eyebrow">Realizované projekty</span>
          </header>
          <ul class="osa-projekty__grid" role="list">
            {realizovane.map((p, i) => (
              <li data-reveal data-reveal-delay={String((i % 4) + 1)}><ProjectCard
                slug={p.id}
                name={p.data.name}
                description={p.data.description}
                accent={p.data.accent}
                relationship={p.data.relationship}
                status={p.data.status}
                topic={p.data.topic}
                external_url={p.data.external_url}
                image={p.data.image}
              /></li>
            ))}
          </ul>
        </div>

        <div id="pripravovane" class="osa-projekty__group" data-reveal>
          <header class="osa-projekty__group-head">
            <span class="osa-eyebrow">Připravované projekty</span>
          </header>
          <ul class="osa-projekty__grid" role="list">
            {pripravovane.map((p, i) => (
              <li data-reveal data-reveal-delay={String((i % 4) + 1)}><ProjectCard
                slug={p.id}
                name={p.data.name}
                description={p.data.description}
                accent={p.data.accent}
                relationship={p.data.relationship}
                status={p.data.status}
                topic={p.data.topic}
                external_url={p.data.external_url}
                image={p.data.image}
              /></li>
            ))}
          </ul>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Base>

<style>
  /* ---------- Dark hero frame ---------- */

  .osa-projekty__hero {
    border-bottom: 1px solid var(--rule);
    position: relative;
    isolation: isolate;
  }
  .osa-projekty__hero-inner { position: relative; z-index: 1; }
  .osa-projekty__hero-inner {
    padding-top: clamp(var(--space-7), 8vw, var(--space-9));
    padding-bottom: var(--space-9);
    display: grid;
    gap: var(--space-6);
  }

  .osa-projekty__head {
    display: grid;
    gap: var(--space-3);
    max-width: 72ch;
  }
  .osa-projekty__h1 {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(2.25rem, 5vw + 0.5rem, 4rem);
    line-height: 1.05;
    letter-spacing: var(--tracking-tight);
    color: var(--fg);
    margin: 0;
    max-width: 22ch;
    text-wrap: balance;
  }
  .osa-projekty__h1-sub {
    display: block;
    color: var(--fg-muted);
    font-weight: 500;
    font-size: clamp(1rem, 0.7vw + 0.8rem, 1.25rem);
    line-height: 1.5;
    margin-top: var(--space-4);
    max-width: 62ch;
  }

  /* ---------- Jump nav (Realizované / Připravované) ---------- */
  .osa-projekty__jumps {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-5);
  }
  .osa-projekty__jump {
    display: inline-grid;
    gap: var(--space-1);
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--fg);
    color: var(--fg);
    text-decoration: none;
    transition: background-color var(--dur-base, 280ms) var(--ease-quart, cubic-bezier(0.25, 1, 0.5, 1)),
                color var(--dur-base, 280ms) var(--ease-quart, cubic-bezier(0.25, 1, 0.5, 1));
  }
  .osa-projekty__jump:hover,
  .osa-projekty__jump:focus-visible {
    background: var(--fg);
    color: var(--bg);
  }
  .osa-projekty__jump-eyebrow { color: var(--fg-muted); }
  .osa-projekty__jump:hover .osa-projekty__jump-eyebrow,
  .osa-projekty__jump:focus-visible .osa-projekty__jump-eyebrow { color: var(--bg); opacity: 0.7; }
  .osa-projekty__jump-label {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--text-md);
    letter-spacing: var(--tracking-tight);
  }

  /* Anchor scroll: leave room above section for sticky header. */
  #realizovane, #pripravovane { scroll-margin-top: 80px; }

  /* ---------- Groups ---------- */

  .osa-projekty__group + .osa-projekty__group {
    margin-top: var(--space-9);
  }
  .osa-projekty__group-head {
    margin: 0 0 var(--space-4);
  }

  /* ---------- Grid ---------- */

  .osa-projekty__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 1fr;
    gap: 0;
    border-top: 1px solid var(--rule);
    border-left: 1px solid var(--rule);
  }
  .osa-projekty__grid > li { display: flex; }
  .osa-projekty__grid > li > * { flex: 1; }

  @media (max-width: 1024px) {
    .osa-projekty__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .osa-projekty__grid { grid-template-columns: 1fr; }
  }
</style>
