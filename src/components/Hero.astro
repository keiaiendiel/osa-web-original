---
import OsaGlyph from './OsaGlyph.astro';
import InlineCTA from './InlineCTA.astro';
import { withBase } from '../utils/url';

// Image-sequence scroll-scrubbing (Apple-style). 84 JPG frames
// extracted z 4.2s placeholder videa (Earth z vesmíru), namapované
// na scroll progress přes výšku PIN wrapperu. Žádný <video> element —
// scrubbing přes <video currentTime> je na mobilech nestabilní;
// preloadované Image() objekty + canvas dávají deterministický 60fps
// scrub bez jitteru.
//
// Sticky-pin pattern: vnější .osa-hero-pin je 200vh vysoký, vnitřní
// .osa-hero je `position: sticky; top: 0; height: 100vh`, takže během
// 100vh scrollu je hero přilepený k viewportu a scrub progress
// reaguje na scroll position. Po 100vh hero "pustí" a stránka pod
// hero se začne posouvat normálně.
const FRAME_COUNT = 84;
const FRAME_BASE = withBase('/images/hero-earth/');
---
<div class="osa-hero-pin">
  <section class="osa-hero osa-dark">
    <canvas
      class="osa-hero__canvas"
      data-hero-canvas
      data-frame-count={FRAME_COUNT}
      data-frame-base={FRAME_BASE}
      aria-hidden="true">
    </canvas>
    <div class="osa-hero__overlay" data-hero-overlay aria-hidden="true"></div>
    {/* První frame jako img poster — viditelný okamžitě, dokud canvas
         neudělá první draw + fallback pro prefers-reduced-motion. */}
    <img
      class="osa-hero__poster"
      src={`${FRAME_BASE}frame-001.jpg`}
      alt=""
      aria-hidden="true"
      loading="eager"
      fetchpriority="high"
    />

    <div class="container-wide osa-hero__inner">
      <div class="osa-hero__eyebrow osa-eyebrow" data-reveal>
        <OsaGlyph size="13px" />
        <span>Pomáháme tvořit&hellip;</span>
      </div>
      <h1 class="osa-hero__h1">
        <span
          class="osa-hero__h1-main"
          data-reveal-words
          data-reveal-words-delay="200"
          data-reveal-words-step="40">Chceme vytvořit moderní, prosperující a hodnotově orientovanou společnost, jejímž smyslem a účelem bude efektivní podpora všech jedinců v jejich plnohodnotné a všestranné seberealizaci.</span>
      </h1>
      <div class="osa-hero__rule" aria-hidden="true" data-reveal style="transition-delay: 1100ms"></div>
      <div class="osa-hero__cta" data-reveal style="transition-delay: 1250ms">
        <InlineCTA href={withBase('/o-spolku/')}>Více o spolku</InlineCTA>
        <InlineCTA href={withBase('/aktuality/')} class="osa-hero__cta-secondary">Aktuality</InlineCTA>
      </div>
    </div>
  </section>
</div>

<script is:inline>
  /*
   * Hero scroll-scrubber se sticky pin pattern.
   *
   * - Pin wrapper (.osa-hero-pin) je 200vh tall.
   * - Sticky inner (.osa-hero) je 100vh, top:0 → během prvních 100vh
   *   scrollu zůstane přilepený k viewportu, pak se pustí.
   * - scrolled = -pinWrapper.getBoundingClientRect().top
   * - range  = pinWrapper.offsetHeight - section.offsetHeight (~100vh)
   * - scrollProgress = scrolled / range, clamped 0..1
   * - videoProgress = min(1, scrollProgress / 0.9) — video doběhne
   *   v 90% pin range; posledních 10% sedí na last frame, abychom
   *   měli prostor mezi koncem videa a unstickem.
   * - frame = round(videoProgress * (FRAME_COUNT - 1))
   * - overlay --scroll-progress = videoProgress (řídí stmavnutí Earth)
   *
   * Reduced motion: zachováme statický frame-001 a žádný scrub.
   */
  (function () {
    var canvas = document.querySelector('[data-hero-canvas]');
    var overlay = document.querySelector('[data-hero-overlay]');
    var poster = document.querySelector('.osa-hero__poster');
    if (!canvas || !overlay) return;
    var section = canvas.parentElement;        // .osa-hero
    var pinWrap = section.parentElement;       // .osa-hero-pin

    var FRAME_COUNT = parseInt(canvas.getAttribute('data-frame-count'), 10) || 84;
    var FRAME_BASE = canvas.getAttribute('data-frame-base') || '/images/hero-earth/';
    // Video doběhne v 90 % pin scroll range. Posledních 10 % range
    // drží frame na konci, dokud se hero neodlepí. Klient prosil
    // "až 85-90 % videa, pak začne scrollování stránky".
    var VIDEO_END_AT = 0.9;

    function frameSrc(i) {
      var n = String(i + 1);
      while (n.length < 3) n = '0' + n;
      return FRAME_BASE + 'frame-' + n + '.jpg';
    }

    var ctx = canvas.getContext('2d', { alpha: true });
    var images = new Array(FRAME_COUNT);
    var loadedCount = 0;
    var currentFrame = -1;
    var pendingFrame = 0;
    var needsDraw = false;
    var inView = true;
    var rmm = window.matchMedia('(prefers-reduced-motion: reduce)');

    function resize() {
      var dpr = Math.min(window.devicePixelRatio || 1, 2);
      var w = canvas.offsetWidth;
      var h = canvas.offsetHeight;
      // Defensive fallback — první resize() po init někdy vidí 0×0.
      if (w === 0 && section) w = section.offsetWidth || section.clientWidth;
      if (h === 0 && section) h = section.offsetHeight || section.clientHeight;
      if (canvas.width !== Math.round(w * dpr) || canvas.height !== Math.round(h * dpr)) {
        canvas.width = Math.round(w * dpr);
        canvas.height = Math.round(h * dpr);
        needsDraw = true;
      }
    }

    function drawFrame(idx) {
      var img = images[idx];
      if (!img || !img.complete || !img.naturalWidth) return false;
      var cw = canvas.width;
      var ch = canvas.height;
      ctx.clearRect(0, 0, cw, ch);
      // cover-fit
      var ir = img.naturalWidth / img.naturalHeight;
      var cr = cw / ch;
      var dw, dh, dx, dy;
      if (ir > cr) {
        dh = ch; dw = ch * ir;
        dx = (cw - dw) / 2; dy = 0;
      } else {
        dw = cw; dh = cw / ir;
        dx = 0; dy = (ch - dh) / 2;
      }
      ctx.drawImage(img, dx, dy, dw, dh);
      return true;
    }

    function updateProgress() {
      if (!pinWrap || !section) return;
      var rect = pinWrap.getBoundingClientRect();
      var range = Math.max(1, pinWrap.offsetHeight - section.offsetHeight);
      var scrolled = -rect.top;
      var scrollProgress = Math.min(1, Math.max(0, scrolled / range));
      var videoProgress = Math.min(1, scrollProgress / VIDEO_END_AT);
      var frame = Math.min(FRAME_COUNT - 1, Math.round(videoProgress * (FRAME_COUNT - 1)));
      if (frame !== pendingFrame) {
        pendingFrame = frame;
        needsDraw = true;
      }
      overlay.style.setProperty('--scroll-progress', videoProgress.toFixed(4));
    }

    function tick() {
      if (inView && needsDraw) {
        var f = pendingFrame;
        var drew = drawFrame(f);
        if (!drew) {
          // fall-back na nejbližší naloadovaný frame
          for (var d = 1; d < FRAME_COUNT && !drew; d++) {
            if (f - d >= 0) drew = drawFrame(f - d);
            if (!drew && f + d < FRAME_COUNT) drew = drawFrame(f + d);
          }
        }
        if (drew) {
          currentFrame = f;
          needsDraw = false;
        }
      }
      requestAnimationFrame(tick);
    }

    function reveal() {
      canvas.classList.add('is-loaded');
      if (poster) poster.classList.add('is-hidden');
    }

    function preload() {
      for (var i = 0; i < FRAME_COUNT; i++) {
        var img = new Image();
        images[i] = img;
        img.decoding = 'async';
        img.src = frameSrc(i);
        (function (idx) {
          images[idx].onload = function () {
            loadedCount++;
            if (idx === 0) {
              needsDraw = true;
              reveal();
            }
            if (idx === pendingFrame) needsDraw = true;
          };
        })(i);
      }
    }

    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function (entries) {
        inView = entries[0].isIntersecting;
      }, { rootMargin: '200px' });
      io.observe(pinWrap);
    }

    if ('ResizeObserver' in window) {
      var ro = new ResizeObserver(function () { resize(); });
      ro.observe(section);
    }

    if (rmm.matches) {
      var only = new Image();
      only.onload = function () { images[0] = only; needsDraw = true; reveal(); };
      only.src = frameSrc(0);
      window.addEventListener('scroll', updateProgress, { passive: true });
      window.addEventListener('resize', function () { resize(); needsDraw = true; });
      resize();
      requestAnimationFrame(tick);
      return;
    }

    resize();
    preload();
    window.addEventListener('scroll', updateProgress, { passive: true });
    window.addEventListener('resize', function () { resize(); needsDraw = true; });
    updateProgress();
    requestAnimationFrame(tick);
  }());
</script>

<style>
  /* PIN wrapper — výška = 200vh, takže sticky inner má 100vh
     scroll-range na "scrub" video před tím, než se pustí. Použito
     :global() protože Astro CSS scoping občas selektor `.osa-hero-pin`
     odhodí, když jediným match elementem je wrapper sám (nikoli něco
     uvnitř s daným atributem). */
  :global(.osa-hero-pin) {
    position: relative;
    height: 200vh;
    background: var(--k-100);
    color: var(--k-0);
  }
  /* Mobile: kratší pin range — na malých zařízeních je 100vh dost
     scrollu na to, aby user měl pocit, že "se stalo dost". */
  @media (max-width: 720px) {
    :global(.osa-hero-pin) { height: 170vh; }
  }

  /* ============================================================
     STICKY hero — přilepený 100vh box. Background canvas + overlay
     + text obsah; opouští viewport teprve když pin wrapper končí.
     ============================================================ */
  .osa-hero {
    --fg: var(--k-0);
    --fg-muted: var(--k-30);
    --bg: var(--k-100);
    background: var(--bg);
    color: var(--fg);
    position: sticky;
    top: 0;
    height: 100vh;
    isolation: isolate;
    overflow: hidden;
    width: 100%;
  }

  /* Statický poster — ukazuje frame 1 než canvas dokreslí. */
  .osa-hero__poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    opacity: 1;
    transition: opacity 200ms linear;
    pointer-events: none;
  }
  .osa-hero__poster.is-hidden { opacity: 0; }

  /* Canvas — fade in 0 → 1 jakmile první frame loaduje. */
  .osa-hero__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    opacity: 0;
    transition: opacity 800ms cubic-bezier(0.25, 1, 0.5, 1);
    pointer-events: none;
    background: var(--bg);
  }
  .osa-hero__canvas.is-loaded { opacity: 1; }

  /* Overlay — gradient s alpha řízenou přes --scroll-progress.
     Bare rgba() v `background` shorthand padá na `none`, takže obě
     stop barvy obsahují calc() přímo. */
  .osa-hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    --scroll-progress: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, calc(0.15 + var(--scroll-progress) * 0.7)),
      rgba(0, 0, 0, calc(0.55 + var(--scroll-progress) * 0.4))
    );
  }

  .osa-hero__inner {
    position: relative;
    z-index: 3;
    height: 100%;
    /* Text padá ke spodnímu okraji sticky boxu přes flex column. */
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: var(--space-5);
    padding-top: var(--space-9);
    padding-bottom: var(--space-9);
  }
  .osa-hero__eyebrow {
    display: inline-flex; align-items: center; gap: var(--space-2);
    color: var(--fg-muted);
  }
  .osa-hero__h1 {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(1.625rem, 2.6vw + 0.85rem, 3.25rem);
    line-height: 1.12;
    letter-spacing: var(--tracking-tight);
    color: var(--fg);
    margin: 0;
    max-width: 32ch;
    text-shadow: 0 1px 28px rgba(0, 0, 0, 0.45);
  }
  .osa-hero__h1-main {
    display: block;
    text-wrap: balance;
  }
  .osa-hero__rule {
    height: 1px;
    background: var(--fg-muted);
    width: 64px;
    transform-origin: left;
  }
  .osa-hero__cta {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    flex-wrap: wrap;
  }
  .osa-hero__cta :global(.osa-hero__cta-secondary) {
    color: var(--fg-muted);
  }
  .osa-hero__cta :global(.osa-hero__cta-secondary:hover) {
    color: var(--fg);
  }
  [data-reveal].osa-hero__rule { transform: scaleX(0); }
  [data-reveal].osa-hero__rule.shown { transform: scaleX(1); opacity: 1; }

  @media (max-width: 720px) {
    .osa-hero__h1 { max-width: 24ch; }
    .osa-hero__cta { gap: var(--space-4); }
  }

  @media (prefers-reduced-motion: reduce) {
    .osa-hero__canvas,
    .osa-hero__poster {
      transition: none;
    }
  }
</style>
