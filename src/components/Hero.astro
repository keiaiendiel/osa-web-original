---
import OsaGlyph from './OsaGlyph.astro';
import InlineCTA from './InlineCTA.astro';
import { withBase } from '../utils/url';

// Image-sequence scroll scrubbing (Apple-style). 84 JPG frames
// extracted z 4.2s placeholder videa (Earth z vesmíru), namapované
// na scroll progress přes výšku hero sekce. Žádný <video> element —
// scrubbing přes <video currentTime> je na mobilech nestabilní;
// preloadované Image() objekty + canvas dávají deterministický 60fps
// scrub bez jitteru.
const FRAME_COUNT = 84;
const FRAME_BASE = withBase('/images/hero-earth/');
---
<section class="osa-hero osa-dark">
  <canvas
    class="osa-hero__canvas"
    data-hero-canvas
    data-frame-count={FRAME_COUNT}
    data-frame-base={FRAME_BASE}
    aria-hidden="true">
  </canvas>
  <div class="osa-hero__overlay" data-hero-overlay aria-hidden="true"></div>
  {/* První frame jako img fallback pro prefers-reduced-motion + dokud
       canvas nedokreslí. position: absolute + z-index: 0 znamená, že
       je pod overlayem, stejně jako canvas. */}
  <img
    class="osa-hero__poster"
    src={`${FRAME_BASE}frame-001.jpg`}
    alt=""
    aria-hidden="true"
    loading="eager"
    fetchpriority="high"
  />

  <div class="container-wide osa-hero__inner">
    <div class="osa-hero__eyebrow osa-eyebrow" data-reveal>
      <OsaGlyph size="13px" />
      <span>Pomáháme tvořit&hellip;</span>
    </div>
    <h1 class="osa-hero__h1">
      <span
        class="osa-hero__h1-main"
        data-reveal-words
        data-reveal-words-delay="200"
        data-reveal-words-step="40">Chceme vytvořit moderní, prosperující a hodnotově orientovanou společnost, jejímž smyslem a účelem bude efektivní podpora všech jedinců v jejich plnohodnotné a všestranné seberealizaci.</span>
    </h1>
    <div class="osa-hero__rule" aria-hidden="true" data-reveal style="transition-delay: 1100ms"></div>
    <div class="osa-hero__cta" data-reveal style="transition-delay: 1250ms">
      <InlineCTA href={withBase('/o-spolku/')}>Více o spolku</InlineCTA>
      <InlineCTA href={withBase('/aktuality/')} class="osa-hero__cta-secondary">Aktuality</InlineCTA>
    </div>
  </div>
</section>

<script is:inline>
  /*
   * Hero scroll-scrubber. Načte všech FRAME_COUNT obrázků jako
   * Image() objekty, na scroll RAF loop kreslí příslušný frame na
   * canvas. Bez RAF throttle by stmavnutí způsobovalo jitter na
   * slabších CPU. Když je hero mimo viewport, přeskočíme práci.
   *
   * `--scroll-progress` CSS custom property se synchronně zapisuje
   * na overlay div, který přes ni řídí svou alpha (rgba s var()).
   */
  (function () {
    var canvas = document.querySelector('[data-hero-canvas]');
    var overlay = document.querySelector('[data-hero-overlay]');
    var poster = document.querySelector('.osa-hero__poster');
    if (!canvas || !overlay) return;
    var section = canvas.parentElement;

    var FRAME_COUNT = parseInt(canvas.getAttribute('data-frame-count'), 10) || 84;
    var FRAME_BASE = canvas.getAttribute('data-frame-base') || '/images/hero-earth/';
    function frameSrc(i) {
      var n = String(i + 1);
      while (n.length < 3) n = '0' + n;
      return FRAME_BASE + 'frame-' + n + '.jpg';
    }

    var ctx = canvas.getContext('2d', { alpha: true });
    var images = new Array(FRAME_COUNT);
    var loadedCount = 0;
    var currentFrame = -1;
    var pendingFrame = 0;
    var needsDraw = false;
    var inView = true;
    var rmm = window.matchMedia('(prefers-reduced-motion: reduce)');

    function resize() {
      var dpr = Math.min(window.devicePixelRatio || 1, 2);
      var w = canvas.offsetWidth;
      var h = canvas.offsetHeight;
      // Pokud je canvas zatím 0×0 (layout ještě neběžel), padáme zpátky
      // na rozměry parent sekce — díky tomu se první draw nepřeskočí.
      if (w === 0 && section) w = section.offsetWidth || section.clientWidth;
      if (h === 0 && section) h = section.offsetHeight || section.clientHeight;
      if (canvas.width !== Math.round(w * dpr) || canvas.height !== Math.round(h * dpr)) {
        canvas.width = Math.round(w * dpr);
        canvas.height = Math.round(h * dpr);
        needsDraw = true;
      }
    }

    function drawFrame(idx) {
      var img = images[idx];
      if (!img || !img.complete || !img.naturalWidth) return false;
      var cw = canvas.width;
      var ch = canvas.height;
      ctx.clearRect(0, 0, cw, ch);
      // cover-fit
      var ir = img.naturalWidth / img.naturalHeight;
      var cr = cw / ch;
      var dw, dh, dx, dy;
      if (ir > cr) {
        dh = ch; dw = ch * ir;
        dx = (cw - dw) / 2; dy = 0;
      } else {
        dw = cw; dh = cw / ir;
        dx = 0; dy = (ch - dh) / 2;
      }
      ctx.drawImage(img, dx, dy, dw, dh);
      return true;
    }

    function updateProgress() {
      if (!section) return;
      var rect = section.getBoundingClientRect();
      var total = section.offsetHeight;
      var scrolled = -rect.top;
      var progress = Math.min(1, Math.max(0, scrolled / total));
      var frame = Math.min(FRAME_COUNT - 1, Math.round(progress * (FRAME_COUNT - 1)));
      if (frame !== pendingFrame) {
        pendingFrame = frame;
        needsDraw = true;
      }
      overlay.style.setProperty('--scroll-progress', progress.toFixed(4));
    }

    function tick() {
      if (inView && needsDraw) {
        // fall-back to nearest loaded frame, dokud nedoběhne preload
        var f = pendingFrame;
        var drew = drawFrame(f);
        if (!drew) {
          for (var d = 1; d < FRAME_COUNT && !drew; d++) {
            if (f - d >= 0) drew = drawFrame(f - d);
            if (!drew && f + d < FRAME_COUNT) drew = drawFrame(f + d);
          }
        }
        if (drew) {
          currentFrame = f;
          needsDraw = false;
        }
      }
      requestAnimationFrame(tick);
    }

    function onScroll() {
      updateProgress();
    }

    function reveal() {
      canvas.classList.add('is-loaded');
      if (poster) poster.classList.add('is-hidden');
    }

    function preload() {
      for (var i = 0; i < FRAME_COUNT; i++) {
        var img = new Image();
        images[i] = img;
        img.decoding = 'async';
        img.src = frameSrc(i);
        (function (idx) {
          images[idx].onload = function () {
            loadedCount++;
            if (idx === 0) {
              // jakmile máme první frame, zviditelníme canvas
              needsDraw = true;
              reveal();
            }
            // dokud se ladí canvas, redraw průběžně, aby uživatel
            // ne-viděl nehybný snímek pokud zrovna scrolluje
            if (idx === pendingFrame) needsDraw = true;
          };
        })(i);
      }
    }

    // IntersectionObserver — vypneme draw práci když hero není ve výhledu
    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function (entries) {
        inView = entries[0].isIntersecting;
      }, { rootMargin: '50px' });
      io.observe(section);
    }

    // ResizeObserver — kreslení canvasu drží sync s reálnou velikostí
    // sekce. resize event sám o sobě nestačí: layout se v Astro někdy
    // dotahuje až po DOMContentLoaded a první resize() při init dostane
    // 0×0. RO chytí změnu hned, jak proběhne první layout.
    if ('ResizeObserver' in window) {
      var ro = new ResizeObserver(function () { resize(); });
      ro.observe(section);
    }

    // Reduced motion: zachováme statický první frame a stmavnutí
    // řízené jen scrollem (bez frame swapování). Pořád preloadneme
    // jeden frame, ostatní necháme být.
    if (rmm.matches) {
      var only = new Image();
      only.onload = function () { images[0] = only; needsDraw = true; reveal(); };
      only.src = frameSrc(0);
      window.addEventListener('scroll', updateProgress, { passive: true });
      window.addEventListener('resize', function () { resize(); needsDraw = true; });
      resize();
      requestAnimationFrame(tick);
      return;
    }

    resize();
    preload();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', function () { resize(); needsDraw = true; });
    updateProgress();
    requestAnimationFrame(tick);
  }());
</script>

<style>
  .osa-hero {
    --fg: var(--k-0);
    --fg-muted: var(--k-30);
    --bg: var(--k-100);
    background: var(--bg);
    color: var(--fg);
    position: relative;
    isolation: isolate;
    overflow: hidden;
    /* Vyšší hero, aby video vyniklo. clamp drží minimum na malých
       displejích a maximum na 4K monitorech. */
    min-height: clamp(680px, 95vh, 1080px);
    /* Žádný display:grid — některé browser kombinace "grid + align-items:end
       + position:absolute children" daly canvasu width 0 při prvním
       layoutu. Pozici dolního obsahu řeší padding-top na .osa-hero__inner. */
  }

  /* Statický poster (první frame) — ukazuje se, dokud canvas
     neproběhne první draw. Eager loading + fetchpriority high
     sníží blank-state při načítání. */
  .osa-hero__poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    opacity: 0;
    transition: opacity 800ms cubic-bezier(0.25, 1, 0.5, 1);
    pointer-events: none;
  }
  .osa-hero__poster:not(.is-hidden) {
    opacity: 1;
  }
  .osa-hero__poster.is-hidden {
    opacity: 0;
    transition: opacity 200ms linear;
  }

  /* Canvas — kreslí aktuální frame. Po načtení prvního obrázku se
     třída `is-loaded` přidá → fade in. */
  .osa-hero__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    opacity: 0;
    transition: opacity 800ms cubic-bezier(0.25, 1, 0.5, 1);
    pointer-events: none;
    background: var(--bg);
  }
  .osa-hero__canvas.is-loaded {
    opacity: 1;
  }

  /* Overlay řídí stmavnutí Earth → silueta → mizí. CSS var
     `--scroll-progress` zapisuje JS na každý scroll event;
     interpoluje se mezi 0 a 1 podle progress hero sekcí.
     Bare rgba() color v `background` shorthand padá na `none`,
     proto `--scroll-progress` interpolujeme přímo uvnitř obou
     gradient stops. Top stop 0.15 → 0.85, bottom stop 0.55 → 0.95. */
  .osa-hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    --scroll-progress: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, calc(0.15 + var(--scroll-progress) * 0.7)),
      rgba(0, 0, 0, calc(0.55 + var(--scroll-progress) * 0.4))
    );
  }

  .osa-hero__inner {
    position: relative;
    z-index: 3;
    /* Vysoký top padding tlačí hlavní obsah blízko spodního okraje
       hero sekce, aby video nahoře dostalo prostor. */
    padding-top: clamp(40vh, 48vh, 540px);
    padding-bottom: var(--space-9);
    display: grid;
    gap: var(--space-5);
  }
  .osa-hero__eyebrow {
    display: inline-flex; align-items: center; gap: var(--space-2);
    color: var(--fg-muted);
  }
  .osa-hero__h1 {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(1.625rem, 2.6vw + 0.85rem, 3.25rem);
    line-height: 1.12;
    letter-spacing: var(--tracking-tight);
    color: var(--fg);
    margin: 0;
    max-width: 32ch;
    /* Subtilní stín pro lepší čitelnost nad videem. */
    text-shadow: 0 1px 28px rgba(0, 0, 0, 0.45);
  }
  .osa-hero__h1-main {
    display: block;
    text-wrap: balance;
  }
  .osa-hero__rule {
    height: 1px;
    background: var(--fg-muted);
    width: 64px;
    margin-top: var(--space-2);
    transform-origin: left;
  }
  .osa-hero__cta {
    margin-top: var(--space-2);
    display: flex;
    align-items: center;
    gap: var(--space-5);
    flex-wrap: wrap;
  }
  .osa-hero__cta :global(.osa-hero__cta-secondary) {
    color: var(--fg-muted);
  }
  .osa-hero__cta :global(.osa-hero__cta-secondary:hover) {
    color: var(--fg);
  }
  [data-reveal].osa-hero__rule { transform: scaleX(0); }
  [data-reveal].osa-hero__rule.shown { transform: scaleX(1); opacity: 1; }

  @media (max-width: 720px) {
    .osa-hero__h1 { max-width: 24ch; }
    .osa-hero__cta { gap: var(--space-4); }
    .osa-hero {
      min-height: clamp(640px, 90vh, 900px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .osa-hero__canvas,
    .osa-hero__poster {
      transition: none;
    }
  }
</style>
