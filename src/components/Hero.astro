---
import OsaGlyph from './OsaGlyph.astro';
import InlineCTA from './InlineCTA.astro';
import { withBase } from '../utils/url';

/*
 * Hero — image-sequence scroll-scrub + intro autoplay + word-stagger exit.
 *
 * Frames: dvojrychlostní extrakce z public/images/hero-sun/space-sun.mp4
 *   • frame-001..045 = 0–3.0 s zdrojového videa @ 15 fps  (INTRO autoplay)
 *   • frame-046..138 = 3.0 s–end @ 3 fps                  (SCRUB on scroll)
 *
 * Stavy:
 *   "intro"  — po načtení 1. framu se rozjede autoplay timer
 *              ~INTRO_DURATION_MS s ease-outem; zastaví na frame
 *              INTRO_FRAME_COUNT-1 a čeká.
 *   "scrub"  — jakmile user scrollne >0.5 % range, autoplay se zruší,
 *              od posledního intro framu se napojí scrub do konce videa.
 *              Při reloadu mid-page (scrollProgress > 0 při init)
 *              startujeme rovnou ve "scrub".
 *
 * Sticky-pin pattern (zachován):
 *   .osa-hero-pin = 170vh (mobile 140vh) → během prvních 100vh scrollu
 *   je .osa-hero přilepený k viewportu, video scrubuje (0..0.7 of pin)
 *   a text mizí po slovech (0..0.85 of pin), pak se sticky pustí.
 */
const FRAME_COUNT = 170;
const INTRO_FRAME_COUNT = 85;
const FRAME_BASE = withBase('/images/hero-sun/');
---
<div class="osa-hero-pin">
  <section class="osa-hero osa-dark">
    <canvas
      class="osa-hero__canvas"
      data-hero-canvas
      data-frame-count={FRAME_COUNT}
      data-intro-frame-count={INTRO_FRAME_COUNT}
      data-frame-base={FRAME_BASE}
      aria-hidden="true">
    </canvas>
    <div class="osa-hero__overlay" data-hero-overlay aria-hidden="true"></div>
    {/* Poster — frame-001 viditelný okamžitě, dokud canvas neudělá první draw. */}
    <img
      class="osa-hero__poster"
      src={`${FRAME_BASE}frame-001.jpg`}
      alt=""
      aria-hidden="true"
      loading="eager"
      fetchpriority="high"
    />

    <div class="container-wide osa-hero__inner">
      <div class="osa-hero__eyebrow osa-eyebrow" data-hero-eyebrow data-reveal>
        <OsaGlyph size="13px" />
        <span>Občanské sdružení Alternativa II</span>
      </div>
      <h1 class="osa-hero__h1">
        <span
          class="osa-hero__h1-main"
          data-hero-text
          data-reveal-words
          data-reveal-words-delay="200"
          data-reveal-words-step="80">Pomáháme tvořit.</span>
      </h1>
      <p class="osa-hero__sub" data-hero-sub data-reveal style="transition-delay: 950ms">
        Spolek pro plnohodnotnou seberealizaci jedince i společnosti.
      </p>
      <div class="osa-hero__rule" aria-hidden="true" data-hero-rule data-reveal style="transition-delay: 1100ms"></div>
      <div class="osa-hero__cta" data-hero-cta data-reveal style="transition-delay: 1250ms">
        <InlineCTA href={withBase('/o-spolku/')}>Kdo jsme</InlineCTA>
        <InlineCTA href={withBase('/projekty/')} class="osa-hero__cta-secondary">Naše projekty</InlineCTA>
      </div>
    </div>
  </section>
</div>

<script is:inline>
  (function () {
    var canvas = document.querySelector('[data-hero-canvas]');
    var overlay = document.querySelector('[data-hero-overlay]');
    var poster = document.querySelector('.osa-hero__poster');
    if (!canvas || !overlay) return;
    var section = canvas.parentElement;        // .osa-hero
    var pinWrap = section.parentElement;       // .osa-hero-pin

    // Sticky hero je 100vh top:0; protože ale page-level header sedí
    // nad ním, na scroll=0 spodek hero přesahuje pod fold o ~header height.
    // CTA pak nejsou vidět hned. Změříme header height a přiteče přes
    // CSS var do padding-bottom — content se zvedne nad záhlaví.
    function syncHeaderH() {
      var h = document.querySelector('.osa-header');
      var px = h ? h.offsetHeight : 0;
      document.documentElement.style.setProperty('--osa-header-h', px + 'px');
    }
    syncHeaderH();
    window.addEventListener('resize', syncHeaderH);

    var FRAME_COUNT = parseInt(canvas.getAttribute('data-frame-count'), 10) || 138;
    var INTRO_FRAME_COUNT = parseInt(canvas.getAttribute('data-intro-frame-count'), 10) || 45;
    var FRAME_BASE = canvas.getAttribute('data-frame-base') || '/images/hero-sun/';

    // Scrub mapuje scroll 0..VIDEO_END_AT → frames INTRO..LAST. Text se
    // začne hýbat AŽ za VIDEO_END_AT, takže během scrubování textu nikdy
    // neopustí svou pozici — to byl klíčový request klienta.
    var VIDEO_END_AT = 0.70;
    // Text exit: pracuje v "scrollProgress" prostoru, ne v normalizovaném p.
    // Per-word stagger startuje až po dokončení videa.
    var WORD_EXIT_START = 0.55;     // 1. slovo začne mizet v tomto scroll progress
    var WORD_STAGGER_SPAN = 0.18;   // přes kolik scroll progress se rozprostře 1.→poslední slovo
    var WORD_FADE_SPAN = 0.10;      // doba (v scroll progress) přes kterou se 1 slovo schová

    // Intro autoplay — 0..3 s zdrojového videa za ~2.7 s s ease-outem.
    var INTRO_DURATION_MS = 3800;

    function frameSrc(i) {
      var n = String(i + 1);
      while (n.length < 3) n = '0' + n;
      return FRAME_BASE + 'frame-' + n + '.jpg';
    }

    var ctx = canvas.getContext('2d', { alpha: true });
    var images = new Array(FRAME_COUNT);
    var loadedCount = 0;
    var pendingFrame = 0;
    var needsDraw = false;
    var inView = true;
    var rmm = window.matchMedia('(prefers-reduced-motion: reduce)');

    var mode = 'intro';        // 'intro' | 'scrub'
    var introStart = 0;
    var introRunning = false;

    function resize() {
      var dpr = Math.min(window.devicePixelRatio || 1, 2);
      var w = canvas.offsetWidth;
      var h = canvas.offsetHeight;
      if (w === 0 && section) w = section.offsetWidth || section.clientWidth;
      if (h === 0 && section) h = section.offsetHeight || section.clientHeight;
      if (canvas.width !== Math.round(w * dpr) || canvas.height !== Math.round(h * dpr)) {
        canvas.width = Math.round(w * dpr);
        canvas.height = Math.round(h * dpr);
        needsDraw = true;
      }
    }

    function drawFrame(idx) {
      var img = images[idx];
      if (!img || !img.complete || !img.naturalWidth) return false;
      var cw = canvas.width;
      var ch = canvas.height;
      ctx.clearRect(0, 0, cw, ch);
      var ir = img.naturalWidth / img.naturalHeight;
      var cr = cw / ch;
      var dw, dh, dx, dy;
      if (ir > cr) {
        dh = ch; dw = ch * ir;
        dx = (cw - dw) / 2; dy = 0;
      } else {
        dw = cw; dh = cw / ir;
        dx = 0; dy = (ch - dh) / 2;
      }
      ctx.drawImage(img, dx, dy, dw, dh);
      return true;
    }

    var inner = section.querySelector('.osa-hero__inner');
    var heroText = section.querySelector('[data-hero-text]');
    var eyebrow = section.querySelector('[data-hero-eyebrow]');
    var sub = section.querySelector('[data-hero-sub]');
    var rule = section.querySelector('[data-hero-rule]');
    var cta = section.querySelector('[data-hero-cta]');
    var heroExitTargets = []; // [{el, factor}] — eyebrow, rule, cta exit s mírně odlišným timingem

    function freezeWordTransitions() {
      if (!heroText) return;
      var ws = heroText.querySelectorAll('.reveal-word');
      ws.forEach(function (w) {
        // jakmile přebíráme řízení nad pozicí slov, vypneme CSS transition,
        // aby scrub nedělal lag — animaci řídí scroll handler v rAF.
        w.style.transition = 'none';
        w.style.willChange = 'transform, opacity';
      });
    }

    function applyTextExit(scrollProgress) {
      if (!heroText) return;
      var words = heroText.querySelectorAll('.reveal-word');
      var n = words.length;
      if (n === 0) return;
      // Pracujeme přímo v scrollProgress prostoru — text se nehne dokud
      // scrollProgress < WORD_EXIT_START (= dokud video nedoběhne).
      for (var i = 0; i < n; i++) {
        var w = words[i];
        var startAt = WORD_EXIT_START + (n <= 1 ? 0 : (i / (n - 1)) * WORD_STAGGER_SPAN);
        var endAt = startAt + WORD_FADE_SPAN;
        var t;
        if (scrollProgress <= startAt) t = 0;
        else if (scrollProgress >= endAt) t = 1;
        else t = (scrollProgress - startAt) / (endAt - startAt);
        // ease-out (cubic) pro hladký dojezd
        var e = 1 - Math.pow(1 - t, 3);
        // translate −0.6em + opacity → 0
        w.style.transform = 'translateY(' + (-e * 0.6).toFixed(3) + 'em)';
        w.style.opacity = (1 - e).toFixed(3);
      }
      // eyebrow / rule / cta — startují ve stejnou chvíli jako 1. slovo
      // a mizí o trochu rychleji, aby celý blok během exit okna zmizel.
      heroExitTargets.forEach(function (item) {
        var sp = Math.max(0, scrollProgress - WORD_EXIT_START) * item.factor;
        var op = Math.max(0, 1 - sp * 4.0);
        var ty = -sp * 60; // px
        item.el.style.opacity = op.toFixed(3);
        item.el.style.transform = 'translateY(' + ty.toFixed(2) + 'px)';
      });
    }

    function resetTextStyles() {
      if (!heroText) return;
      var words = heroText.querySelectorAll('.reveal-word');
      words.forEach(function (w) {
        w.style.transform = '';
        w.style.opacity = '';
      });
      heroExitTargets.forEach(function (item) {
        item.el.style.opacity = '';
        item.el.style.transform = '';
      });
    }

    function getScrollProgress() {
      if (!pinWrap || !section) return 0;
      var rect = pinWrap.getBoundingClientRect();
      var range = Math.max(1, pinWrap.offsetHeight - section.offsetHeight);
      var scrolled = -rect.top;
      return Math.min(1, Math.max(0, scrolled / range));
    }

    function frameForScrub(scrollProgress) {
      var videoProgress = Math.min(1, scrollProgress / VIDEO_END_AT);
      var span = (FRAME_COUNT - INTRO_FRAME_COUNT);
      var f = (INTRO_FRAME_COUNT - 1) + Math.round(videoProgress * span);
      if (f >= FRAME_COUNT) f = FRAME_COUNT - 1;
      if (f < 0) f = 0;
      return { frame: f, videoProgress: videoProgress };
    }

    function setOverlayProgress(videoProgress) {
      overlay.style.setProperty('--scroll-progress', videoProgress.toFixed(4));
    }

    function startIntro() {
      if (mode !== 'intro') return;
      introRunning = true;
      introStart = performance.now();
      requestAnimationFrame(introTick);
    }

    function introTick(now) {
      if (!introRunning) return;
      if (mode !== 'intro') { introRunning = false; return; }
      var t = (now - introStart) / INTRO_DURATION_MS;
      if (t > 1) t = 1;
      // ease-out (quadratic) — gentle deceleration
      var e = 1 - Math.pow(1 - t, 2);
      var f = Math.round(e * (INTRO_FRAME_COUNT - 1));
      if (f !== pendingFrame) {
        pendingFrame = f;
        needsDraw = true;
      }
      // pomalu zvedáme overlay alphu i během intra (drobný drift)
      setOverlayProgress(t * 0.2);
      if (t < 1) {
        requestAnimationFrame(introTick);
      } else {
        introRunning = false;
        // držíme se na last intro frame, čekáme na scroll
        pendingFrame = INTRO_FRAME_COUNT - 1;
        needsDraw = true;
      }
    }

    function switchToScrub(scrollProgress) {
      mode = 'scrub';
      introRunning = false;
      freezeWordTransitions();
      // okamžitě nastavíme správný frame podle aktuálního scrollu
      var s = frameForScrub(scrollProgress);
      pendingFrame = s.frame;
      needsDraw = true;
      setOverlayProgress(s.videoProgress);
      applyTextExit(scrollProgress);
    }

    function onScroll() {
      var sp = getScrollProgress();
      if (mode === 'intro') {
        if (sp > 0.005) {
          switchToScrub(sp);
        }
        return;
      }
      // scrub
      var s = frameForScrub(sp);
      if (s.frame !== pendingFrame) {
        pendingFrame = s.frame;
        needsDraw = true;
      }
      setOverlayProgress(s.videoProgress);
      applyTextExit(sp);
    }

    function tick() {
      if (inView && needsDraw) {
        var f = pendingFrame;
        var drew = drawFrame(f);
        if (!drew) {
          for (var d = 1; d < FRAME_COUNT && !drew; d++) {
            if (f - d >= 0) drew = drawFrame(f - d);
            if (!drew && f + d < FRAME_COUNT) drew = drawFrame(f + d);
          }
        }
        if (drew) needsDraw = false;
      }
      requestAnimationFrame(tick);
    }

    function reveal() {
      canvas.classList.add('is-loaded');
      if (poster) poster.classList.add('is-hidden');
    }

    function preload() {
      // poster + intro frames eager (ASAP), zbytek se přihazuje s nižší
      // prioritou ale v pořadí indexů, takže scrub má co kreslit.
      for (var i = 0; i < FRAME_COUNT; i++) {
        (function (idx) {
          var img = new Image();
          images[idx] = img;
          img.decoding = 'async';
          img.onload = function () {
            loadedCount++;
            if (idx === 0) {
              needsDraw = true;
              reveal();
              // start intro až když máme 1. frame; reálně ale počkáme i na
              // intro range (tj. ~30 framů), aby autoplay nezakopl. Pokud
              // user mezitím scrollne, switchToScrub() se postará.
              maybeStartIntro();
            }
            if (idx === pendingFrame) needsDraw = true;
            if (idx === INTRO_FRAME_COUNT - 1) maybeStartIntro();
          };
          img.src = frameSrc(idx);
        })(i);
      }
    }

    var introStarted = false;
    function maybeStartIntro() {
      if (introStarted || mode !== 'intro') return;
      // potřebujeme aspoň první frame; intro frames se loadují paralelně,
      // většinou jsou hotové do 100–200 ms. Pokud user reloadl mid-page,
      // přeskočíme intro úplně.
      if (getScrollProgress() > 0.005) {
        switchToScrub(getScrollProgress());
        introStarted = true;
        return;
      }
      if (!images[0] || !images[0].complete) return;
      introStarted = true;
      startIntro();
    }

    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function (entries) {
        inView = entries[0].isIntersecting;
      }, { rootMargin: '200px' });
      io.observe(pinWrap);
    }

    if ('ResizeObserver' in window) {
      var ro = new ResizeObserver(function () { resize(); });
      ro.observe(section);
    }

    // shromáždíme exit targets pro eyebrow/rule/cta (mírně různé tempo)
    function collectExitTargets() {
      heroExitTargets = [];
      if (eyebrow) heroExitTargets.push({ el: eyebrow, factor: 1.4 });
      if (sub) heroExitTargets.push({ el: sub, factor: 1.1 });
      if (rule) heroExitTargets.push({ el: rule, factor: 1.0 });
      if (cta) heroExitTargets.push({ el: cta, factor: 0.8 });
    }
    collectExitTargets();

    if (rmm.matches) {
      // reduced motion: statický 1. frame, žádný scrub, žádný text exit.
      var only = new Image();
      only.onload = function () { images[0] = only; needsDraw = true; reveal(); };
      only.src = frameSrc(0);
      window.addEventListener('resize', function () { resize(); needsDraw = true; });
      resize();
      requestAnimationFrame(tick);
      return;
    }

    resize();
    preload();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', function () { resize(); needsDraw = true; });
    // Pokud user reloadl mid-page, init scroll handler ihned aby nebyl flash.
    onScroll();
    requestAnimationFrame(tick);
  }());
</script>

<style>
  /* PIN wrapper — výška určuje, jak dlouho je sticky hero přilepený.
     Klient: méně černé na konci → 170vh desktop, 140vh mobile.
     Negativní margin-top vytlačí pin pod page-level header (sticky,
     z-index:30) tak, aby hero hned od scroll=0 zabíralo celý viewport
     a první scroll input okamžitě začal scrubovat video — žádná
     "fáze 0" kdy se text posune o výšku menu baru. */
  :global(.osa-hero-pin) {
    position: relative;
    height: 155vh;
    margin-top: calc(-1 * var(--osa-header-h, 56px));
    background: var(--k-100);
    color: var(--k-0);
  }
  @media (max-width: 720px) {
    :global(.osa-hero-pin) { height: 130vh; }
  }

  .osa-hero {
    --fg: var(--k-0);
    --fg-muted: var(--k-30);
    --bg: var(--k-100);
    background: var(--bg);
    color: var(--fg);
    position: sticky;
    top: 0;
    height: 100vh;
    isolation: isolate;
    overflow: hidden;
    width: 100%;
  }

  .osa-hero__poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    opacity: 1;
    transition: opacity 200ms linear;
    pointer-events: none;
  }
  .osa-hero__poster.is-hidden { opacity: 0; }

  .osa-hero__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    opacity: 0;
    transition: opacity 800ms cubic-bezier(0.25, 1, 0.5, 1);
    pointer-events: none;
    background: var(--bg);
  }
  .osa-hero__canvas.is-loaded { opacity: 1; }

  /* Overlay — gradient s alpha řízenou přes --scroll-progress.
     Klient: brightness videa může být vyšší → overlay alpha cca na
     polovinu předchozí. Bottom stop drží trochu víc kontrastu, aby
     text zůstal čitelný i přes světlejší pozadí. */
  .osa-hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    --scroll-progress: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, calc(0.05 + var(--scroll-progress) * 0.28)),
      rgba(0, 0, 0, calc(0.28 + var(--scroll-progress) * 0.22))
    );
  }

  .osa-hero__inner {
    position: relative;
    z-index: 3;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: var(--space-4);
    /* Padding-top zahrnuje výšku page-level header, aby content nemohl
       překrývat sticky header (z-index:30 nad hero). */
    padding-top: calc(var(--osa-header-h, 56px) + var(--space-4));
    padding-bottom: max(var(--space-6), env(safe-area-inset-bottom));
  }
  /* Mezi rule a CTA dáme trošku víc dechu než zbytek gridu. */
  .osa-hero__inner > .osa-hero__rule { margin-top: var(--space-2); }
  .osa-hero__inner > .osa-hero__cta { margin-top: 0; }
  .osa-hero__eyebrow {
    display: inline-flex; align-items: center; gap: var(--space-2);
    color: var(--fg-muted);
    will-change: transform, opacity;
  }
  .osa-hero__h1 {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(2.75rem, 7vw + 1rem, 7rem);
    line-height: 1.02;
    letter-spacing: var(--tracking-tight);
    color: var(--fg);
    margin: 0;
    max-width: 18ch;
    text-shadow: 0 1px 28px rgba(0, 0, 0, 0.45);
  }
  .osa-hero__sub {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(1.05rem, 0.8vw + 0.85rem, 1.5rem);
    line-height: 1.35;
    color: var(--fg-muted);
    margin: 0;
    max-width: 38ch;
    text-shadow: 0 1px 18px rgba(0, 0, 0, 0.45);
    will-change: transform, opacity;
  }
  .osa-hero__h1-main {
    display: block;
    text-wrap: balance;
  }
  /* word stagger — exit pohyb řídí JS přes inline transform/opacity.
     Tady jen optimalizace renderu. */
  .osa-hero__h1-main :global(.reveal-word) {
    display: inline-block;
    will-change: transform, opacity;
  }
  .osa-hero__rule {
    height: 1px;
    background: var(--fg-muted);
    width: 64px;
    transform-origin: left;
    will-change: transform, opacity;
  }
  .osa-hero__cta {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    flex-wrap: wrap;
    will-change: transform, opacity;
  }
  .osa-hero__cta :global(.osa-hero__cta-secondary) {
    color: var(--fg-muted);
  }
  .osa-hero__cta :global(.osa-hero__cta-secondary:hover) {
    color: var(--fg);
  }
  [data-reveal].osa-hero__rule { transform: scaleX(0); }
  [data-reveal].osa-hero__rule.shown { transform: scaleX(1); opacity: 1; }

  @media (max-width: 720px) {
    .osa-hero__h1 { max-width: 24ch; }
    .osa-hero__cta { gap: var(--space-4); }
  }

  @media (prefers-reduced-motion: reduce) {
    .osa-hero__canvas,
    .osa-hero__poster {
      transition: none;
    }
  }
</style>
