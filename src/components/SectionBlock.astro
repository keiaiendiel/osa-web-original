---
interface Props {
  eyebrow?: string;
  heading: string;
  ctaHref?: string;
  ctaLabel?: string;
  expandableLabel?: string;
}
const { eyebrow, heading, ctaHref, ctaLabel, expandableLabel } = Astro.props;
---
<section class="osa-section-block" data-reveal>
  {eyebrow && <span class="osa-section-block__mark" aria-hidden="true">{eyebrow}</span>}
  <div class="osa-section-block__content">
    <h3 class="osa-h3 osa-section-block__heading">{heading}</h3>
    <div class="osa-section-block__body osa-body">
      <slot />
    </div>
    {expandableLabel && (
      <details class="osa-section-block__details">
        <summary>{expandableLabel}</summary>
        <div class="osa-section-block__details-body osa-body">
          <slot name="details" />
        </div>
      </details>
    )}
    <slot name="footer">
      {ctaHref && ctaLabel && (
        <footer class="osa-section-block__foot">
          <a class="osa-inline-cta" href={ctaHref}>
            <span class="osa-inline-cta__chevron" aria-hidden="true"></span>
            <span>{ctaLabel}</span>
          </a>
        </footer>
      )}
    </slot>
  </div>
</section>

<style>
  /* Numbered editorial section. Mirrors the VPD chapter-head pattern: the
     step number is a big sans numeral (not a small eyebrow), heading and
     body flow in the right column. On mobile the number keeps its place
     above the heading but shrinks so it doesn't dominate the viewport.
     v8.2: optional <details> expand for richer copy + a "footer" named
     slot so call sites can render multiple CTAs side by side. */
  .osa-section-block {
    display: grid;
    grid-template-columns: auto 1fr;
    column-gap: var(--space-6);
    padding: var(--space-7) 0 var(--space-6);
    border-top: 1px solid var(--rule);
    align-items: start;
  }
  .osa-section-block:last-of-type { border-bottom: 1px solid var(--rule); }

  .osa-section-block__mark {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(2.8rem, 7.2vw, 4.8rem);
    line-height: 0.9;
    color: var(--fg);
    letter-spacing: -0.02em;
    margin: 0;
    min-width: 3ch;
  }

  .osa-section-block__content {
    display: grid;
    gap: var(--space-4);
    max-width: 64ch;
  }
  .osa-section-block__heading {
    margin: 0;
    font-size: var(--text-3xl);
    letter-spacing: var(--tracking-tight);
    line-height: var(--lh-snug);
    font-weight: 600;
  }
  .osa-section-block__body { color: var(--fg); }
  .osa-section-block__body :global(p) { margin: 0 0 var(--space-3); }
  .osa-section-block__body :global(p:last-child) { margin-bottom: 0; }

  /* Collapsible "Více" detail block */
  .osa-section-block__details {
    border-top: 1px solid var(--rule);
    padding-top: var(--space-3);
  }
  .osa-section-block__details > summary {
    cursor: pointer;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-wide);
    color: var(--fg);
    list-style: none;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .osa-section-block__details > summary::-webkit-details-marker { display: none; }
  .osa-section-block__details > summary::before {
    content: "+";
    display: inline-flex;
    width: 1em;
    justify-content: center;
    color: var(--fg-muted);
  }
  .osa-section-block__details[open] > summary::before { content: "−"; }
  .osa-section-block__details-body {
    margin-top: var(--space-3);
    color: var(--fg-muted);
  }
  .osa-section-block__details-body :global(p) { margin: 0 0 var(--space-3); }
  .osa-section-block__details-body :global(p:last-child) { margin-bottom: 0; }
  .osa-section-block__details-body :global(ul) {
    margin: var(--space-3) 0;
    padding-left: var(--space-5);
  }
  .osa-section-block__details-body :global(li) {
    margin-bottom: var(--space-2);
  }

  .osa-section-block__foot { margin-top: var(--space-1); }

  /* Mobile: collapse to single column, eyebrow-style label */
  @media (max-width: 720px) {
    .osa-section-block {
      grid-template-columns: 1fr;
      row-gap: var(--space-2);
      padding: var(--space-6) 0 var(--space-5);
    }
    .osa-section-block__mark {
      font-family: var(--font-sans);
      font-weight: 500;
      font-size: var(--text-2xs);
      letter-spacing: var(--tracking-wider);
      line-height: var(--lh-tight);
      text-transform: uppercase;
      color: var(--fg);
      min-width: 0;
    }
  }

  .osa-inline-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font: 600 var(--text-sm) / 1 var(--font-sans);
    letter-spacing: var(--tracking-wide);
    color: var(--fg);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: text-underline-offset var(--dur-base) var(--ease-standard);
  }
  .osa-inline-cta:hover { text-underline-offset: 5px; opacity: 1; }
  .osa-inline-cta__chevron {
    width: 10px;
    height: 10px;
    background: currentColor;
    clip-path: polygon(0 0, 100% 50%, 0 100%);
    flex-shrink: 0;
    transition: transform var(--dur-base) var(--ease-standard);
  }
  .osa-inline-cta:hover .osa-inline-cta__chevron { transform: translateX(3px); }
</style>
