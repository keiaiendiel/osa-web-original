---
interface Props {
  eyebrow?: string;
  heading: string;
  ctaHref?: string;
  ctaLabel?: string;
}
const { eyebrow, heading, ctaHref, ctaLabel } = Astro.props;
---
<section class="osa-section-block">
  <header class="osa-section-block__head">
    {eyebrow && <span class="osa-eyebrow osa-section-block__eyebrow">{eyebrow}</span>}
    <h3 class="osa-h3 osa-section-block__heading">{heading}</h3>
  </header>
  <div class="osa-section-block__body osa-body">
    <slot />
  </div>
  {ctaHref && ctaLabel && (
    <footer class="osa-section-block__foot">
      <a class="osa-inline-cta" href={ctaHref}>
        <span class="osa-inline-cta__chevron" aria-hidden="true"></span>
        <span>{ctaLabel}</span>
      </a>
    </footer>
  )}
</section>

<style>
  .osa-section-block {
    display: grid;
    gap: var(--space-4);
    padding: var(--space-6) 0;
    border-top: 1px solid var(--rule);
  }
  .osa-section-block:last-child { border-bottom: 1px solid var(--rule); }
  .osa-section-block__head  { display: grid; gap: var(--space-2); }
  .osa-section-block__eyebrow { color: var(--fg-muted); }
  .osa-section-block__heading { margin: 0; }
  .osa-section-block__body    { color: var(--fg); max-width: 64ch; }
  .osa-section-block__body :global(p) { margin: 0 0 var(--space-3); }
  .osa-section-block__body :global(p:last-child) { margin-bottom: 0; }
  .osa-section-block__foot    { margin-top: var(--space-2); }

  .osa-inline-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font: 600 var(--text-sm) / 1 var(--font-sans);
    letter-spacing: var(--tracking-wide);
    color: var(--fg);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .osa-inline-cta__chevron {
    width: 10px;
    height: 10px;
    background: currentColor;
    clip-path: polygon(0 0, 100% 50%, 0 100%);
    flex-shrink: 0;
  }
</style>
