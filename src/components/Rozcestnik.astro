---
import { getCollection } from 'astro:content';
import ProjectCard from './ProjectCard.astro';
import { withBase } from '../utils/url';

/*
 * Landing rozcestník: a curated subset (4 + 4) split into REALIZOVANÉ
 * and PŘIPRAVOVANÉ. The full list lives at /projekty/. Slugs below pin
 * exactly which entries surface on the homepage; everyone else is
 * routed via "Další projekty".
 */
const LANDING_REALIZOVANE = [
  'kreativni-prostory',
  'vyletna',
  'paint-ball',
  'volnocasova-centra',
];
const LANDING_PRIPRAVOVANE = [
  'mestsky-inkubator',
  'kreditni-system',
  'univerz',
  'akcni-tabory',
];

const all = await getCollection('subProjects', e => e.data.status !== 'draft');
const bySlug = new Map(all.map(p => [p.id, p]));

const realizovane = LANDING_REALIZOVANE
  .map(slug => bySlug.get(slug))
  .filter(<T,>(p: T | undefined): p is T => Boolean(p));

const pripravovane = LANDING_PRIPRAVOVANE
  .map(slug => bySlug.get(slug))
  .filter(<T,>(p: T | undefined): p is T => Boolean(p));
---
<section class="osa-rozcestnik section osa-dark">
  <div class="container-wide">
    <header class="osa-rozcestnik__head" data-reveal>
      <span class="osa-eyebrow osa-rozcestnik__eyebrow">Vybrané projekty</span>
      <h2 class="osa-h2 osa-rozcestnik__title">Naše spolkové projekty</h2>
    </header>

    <div class="osa-rozcestnik__group" data-reveal>
      <header class="osa-rozcestnik__group-head">
        <span class="osa-eyebrow osa-rozcestnik__group-eyebrow">Realizované</span>
      </header>
      <ul class="osa-rozcestnik__grid" role="list">
        {realizovane.map((p, i) => (
          <li
            data-reveal
            data-reveal-delay={String((i % 4) + 1)}
          ><ProjectCard
            slug={p.id}
            name={p.data.name}
            description={p.data.description}
            accent={p.data.accent}
            relationship={p.data.relationship}
            status={p.data.status}
            topic={p.data.topic}
            external_url={p.data.external_url}
            image={p.data.image}
          /></li>
        ))}
      </ul>
    </div>

    <div class="osa-rozcestnik__group" data-reveal>
      <header class="osa-rozcestnik__group-head">
        <span class="osa-eyebrow osa-rozcestnik__group-eyebrow">Připravované</span>
      </header>
      <ul class="osa-rozcestnik__grid" role="list">
        {pripravovane.map((p, i) => (
          <li
            data-reveal
            data-reveal-delay={String((i % 4) + 1)}
          ><ProjectCard
            slug={p.id}
            name={p.data.name}
            description={p.data.description}
            accent={p.data.accent}
            relationship={p.data.relationship}
            status={p.data.status}
            topic={p.data.topic}
            external_url={p.data.external_url}
            image={p.data.image}
          /></li>
        ))}
      </ul>
    </div>

    <div class="osa-rozcestnik__more" data-reveal>
      <a class="btn" href={withBase('/projekty/')} data-wipe>Další projekty</a>
    </div>
  </div>
</section>

<style>
  .osa-rozcestnik__head {
    display: grid;
    gap: var(--space-3);
    max-width: 64ch;
    margin: 0 0 var(--space-7);
  }
  .osa-rozcestnik__title { margin: 0; }

  .osa-rozcestnik__group + .osa-rozcestnik__group {
    margin-top: var(--space-7);
  }
  .osa-rozcestnik__group-head {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    margin: 0 0 var(--space-4);
  }
  .osa-rozcestnik__group-eyebrow {
    color: var(--fg);
  }

  .osa-rozcestnik__grid  {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 1fr;
    gap: 0;
    border-top: 2px solid var(--rule);
    border-left: 2px solid var(--rule);
  }
  .osa-rozcestnik__grid > li { display: flex; }
  .osa-rozcestnik__grid > li > * { flex: 1; }

  /* ---------- Dramatic per-card reveal ----------
     The global [data-reveal] uses translateY(24px) + 600ms — on a section
     the user has scrolled past quickly, the motion is barely perceptible.
     For Rozcestník we want the cards to feel like they're stepping in,
     so we override with a larger translate, a longer duration, and a
     wider per-card stagger. Hidden state is set on the <li>; the card
     itself never moves, which keeps the slider on mobile clean. */
  .osa-rozcestnik__grid > li[data-reveal] {
    opacity: 0;
    transform: translateY(56px);
    transition:
      opacity 900ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 900ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .osa-rozcestnik__grid > li[data-reveal].shown {
    opacity: 1;
    transform: translateY(0);
  }
  .osa-rozcestnik__grid > li[data-reveal][data-reveal-delay='1'] { transition-delay: 80ms; }
  .osa-rozcestnik__grid > li[data-reveal][data-reveal-delay='2'] { transition-delay: 200ms; }
  .osa-rozcestnik__grid > li[data-reveal][data-reveal-delay='3'] { transition-delay: 320ms; }
  .osa-rozcestnik__grid > li[data-reveal][data-reveal-delay='4'] { transition-delay: 440ms; }

  .osa-rozcestnik__more {
    display: flex;
    margin: var(--space-7) 0 0;
    justify-content: flex-start;
  }

  @media (max-width: 1024px) {
    .osa-rozcestnik__grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* Mobile: horizontal scroll-snap slider for each group.
     - Each card sits at ~85vw so the next one peeks in.
     - scroll-snap-type: x mandatory makes swipe feel "magnetic".
     - The bordered frame is removed so the natural card edges read as
       discrete slides. */
  @media (max-width: 720px) {
    .osa-rozcestnik__grid {
      display: flex;
      grid-template-columns: none;
      grid-auto-rows: auto;
      gap: var(--space-3);
      border: 0;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      scroll-padding-inline: var(--gutter, 1rem);
      scroll-behavior: smooth;
      padding: 0 var(--gutter, 1rem) var(--space-3);
      margin: 0 calc(-1 * var(--gutter, 1rem));
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
      overscroll-behavior-x: contain;
      /* Lock vertical movement entirely so a horizontal swipe never
         translates into a tiny y-jitter from page-level scroll chaining. */
      touch-action: pan-x;
    }
    .osa-rozcestnik__grid::-webkit-scrollbar { display: none; }
    .osa-rozcestnik__grid > li {
      flex: 0 0 85%;
      scroll-snap-align: start;
      scroll-snap-stop: always;
      /* Cancel the global [data-reveal] hide-transform inside the
         slider — without this, cards entering the viewport from the
         right wiggle 24px vertically as IntersectionObserver fires. */
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
    .osa-rozcestnik__grid > li:last-child {
      padding-right: var(--space-2);
    }
  }
</style>
