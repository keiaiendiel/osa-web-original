---
interface Props {
  href: string;
  external?: boolean;
  class?: string;
}
const { href, external = false, class: className } = Astro.props;
const isExternal = external || /^https?:\/\//.test(href);
const isMailto   = href.startsWith('mailto:');
---
<a
  href={href}
  class:list={['osa-inline-cta', className]}
  rel={isExternal ? 'noopener' : undefined}
  target={isExternal ? '_blank' : undefined}>
  <span class="osa-inline-cta__chevron" aria-hidden="true"></span>
  <span class="osa-inline-cta__label"><slot /></span>
</a>

<style>
  .osa-inline-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font: 600 var(--text-sm) / 1 var(--font-sans);
    letter-spacing: var(--tracking-wide);
    color: var(--fg);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }
  .osa-inline-cta__chevron {
    width: 10px;
    height: 10px;
    background: currentColor;
    clip-path: polygon(0 0, 100% 50%, 0 100%);
    flex-shrink: 0;
  }
</style>
